{
  "name": "drift-lang",
  "displayName": "Drift",
  "description": "Syntax highlighting for the Drift intent-based agent language.",
  "version": "0.1.0",
  "publisher": "rileyq7",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "repository": { "type": "git", "url": "https://github.com/rileyq7/drift" },
  "contributes": {
    "languages": [
      {
        "id": "drift",
        "aliases": ["Drift", "drift"],
        "extensions": [".drift"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "drift",
        "scopeName": "source.drift",
        "path": "./syntaxes/drift.tmLanguage.json"
      }
    ]
  }
}
