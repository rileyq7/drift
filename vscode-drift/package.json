{
  "name": "drift-lang",
  "displayName": "Drift",
  "description": "Syntax highlighting for the Drift intent-based agent language.",
  "version": "0.1.0",
  "publisher": "rileyq7",
  "license": "MIT",
  "icon": "icons/drift-icon.png",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "keywords": ["drift", "agents", "llm", "dsl", "ai"],
  "repository": { "type": "git", "url": "https://github.com/rileyq7/drift" },
  "bugs": { "url": "https://github.com/rileyq7/drift/issues" },
  "homepage": "https://github.com/rileyq7/drift#readme",
  "contributes": {
    "languages": [
      {
        "id": "drift",
        "aliases": ["Drift", "drift"],
        "extensions": [".drift"],
        "configuration": "./language-configuration.json",
        "icon": { "light": "./icons/drift-icon.png", "dark": "./icons/drift-icon.png" }
      }
    ],
    "grammars": [
      {
        "language": "drift",
        "scopeName": "source.drift",
        "path": "./syntaxes/drift.tmLanguage.json"
      }
    ]
  }
}
