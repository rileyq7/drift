# Copy to .env and fill in your real values.
# Never commit .env — it's gitignored.

# Anthropic API key — used by AnthropicProvider in drift/runtime/core.py
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: set to 1 to force the mock provider even when a key is present.
# Useful for offline development and tests.
DRIFT_USE_MOCK=0
